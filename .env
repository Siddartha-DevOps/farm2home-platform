# ______ Server ___________________________________________

NODE_ENV=development
PORT=5000

# ─── Database ────────────────────────────────────────────

 MONGO_URI=mongodb://localhost:27017/farm2home 

# If using PostgreSQL instead:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/farm2home  

# ─── JWT ───────────────────────────────────────────────────────────

JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
  

# ─── Razorpay (Indian payments) ─────────────────────────────────────────────── 
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx 
RAZORPAY_KEY_SECRET=your_razorpay_key_secret 
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret  

# ─── AWS S3 (product image uploads) ──────────────────────────────────────────

AWS_ACCESS_KEY_ID=your_aws_access_key 
AWS_SECRET_ACCESS_KEY=your_aws_secret_key 
AWS_REGION=ap-south-1 AWS_S3_BUCKET=farm2home-product-images  

# ─── Email (order confirmations) ────────────────────────────────────────────── 

SMTP_HOST=smtp.gmail.com SMTP_PORT=587 
SMTP_USER=your_email@gmail.com SMTP_PASS=your_app_password 
FROM_EMAIL=noreply@farm2home.com  

# ─── Frontend ───────────────────────────────────────────────────────────────── 

VITE_API_URL=http://localhost:5000/api



# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=farm2home_secret
MONGO_DB=farm2home

# JWT
JWT_SECRET=farm2home_jwt_secret_docker

# Mongo Express
ME_USERNAME=admin
ME_PASSWORD=pass


